<body class="bg-surface-soft font-body-reg text-on-surface antialiased">
<!-- TopAppBar -->
<header class="w-full top-0 sticky z-40 bg-surface-soft">
<div class="flex justify-between items-center px-gutter py-base max-w-[1024px] mx-auto w-full h-[64px]">
<h1 class="font-display-lg text-display-lg text-primary">List&amp;GO</h1>
<div class="flex items-center gap-4">
<div class="relative p-2 rounded-full hover:bg-surface-container-low transition-colors cursor-pointer">
<span class="material-symbols-outlined text-on-surface-variant">notifications</span>
<span class="absolute top-2 right-2 w-2 h-2 bg-error rounded-full border border-surface-soft"></span>
</div>
<div class="p-2 rounded-full hover:bg-surface-container-low transition-colors cursor-pointer">
<span class="material-symbols-outlined text-on-surface-variant">settings</span>
</div>
</div>
</div>
</header>
<main class="pb-32">
<!-- Search & Filter Section -->
<section class="px-safe-margin pt-2">
<!-- Search Bar -->
<div class="relative group mb-4">
<span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-on-surface-variant">search</span>
<input class="w-full h-12 pl-12 pr-4 bg-surface-pure border-none rounded-xl recipe-card-shadow focus:ring-2 focus:ring-primary-container transition-all placeholder:text-on-surface-variant/60 font-body-reg" placeholder="Search recipes..." type="text">
</div>
<!-- Horizontal Category Chips -->
<div class="flex flex-wrap gap-2"><button class="active-chip flex items-center gap-1 px-3 py-1.5 rounded-full border border-outline-variant transition-all active:scale-95 text-badge-caps font-badge-caps"><span class="material-symbols-outlined text-[18px]">grid_view</span>All</button><button class="flex items-center gap-1 px-3 py-1.5 rounded-full border border-outline-variant transition-all active:scale-95 text-badge-caps font-badge-caps bg-surface-pure text-on-surface-variant">
<span class="material-symbols-outlined text-[18px]">favorite</span>
                Favorites
            </button>
<button class="bg-surface-pure text-on-surface-variant flex items-center gap-1 px-3 py-1.5 rounded-full border border-outline-variant hover:bg-surface-container-low transition-all active:scale-95 text-badge-caps font-badge-caps">
<span class="material-symbols-outlined text-[18px]">timer</span>
                30 min
            </button>
<button class="bg-surface-pure text-on-surface-variant flex items-center gap-1 px-3 py-1.5 rounded-full border border-outline-variant hover:bg-surface-container-low transition-all active:scale-95 text-badge-caps font-badge-caps">
<span class="material-symbols-outlined text-[18px]">history</span>
                Recent
            </button>
</div>
</section>
<!-- Recipes Grid/List -->
<section class="px-safe-margin mt-6 flex flex-col gap-list-item-gap">
<!-- Recipe Card 1 -->
<div class="bg-surface-pure rounded-xl p-4 recipe-card-shadow flex justify-between items-center">
<div class="flex-1 pr-4">
<div class="flex items-center gap-2 mb-1">
<span class="bg-primary/10 text-primary px-2 py-0.5 rounded font-badge-caps text-[10px]">ITALIAN</span>
<div class="flex items-center gap-1 text-text-dimmed">
<span class="material-symbols-outlined text-[14px]">schedule</span>
<span class="text-unit-label font-unit-label">25m</span>
</div>
</div>
<h3 class="text-item-name font-item-name text-on-surface mb-1 leading-tight">Creamy Pesto Pasta</h3>
<p class="text-on-surface-variant/80 text-unit-label font-unit-label line-clamp-1">Fresh basil pesto with pine nuts and parmesan cheese over al dente penne.</p>
</div>
<button aria-label="Add to Plan" class="h-thumb-touch w-thumb-touch flex items-center justify-center bg-primary-container/10 text-primary rounded-full active:scale-95 transition-transform">
<span class="material-symbols-outlined" style="font-variation-settings: &quot;FILL&quot; 1;">calendar_add_on</span>
</button>
</div>
<!-- Recipe Card 2 -->
<div class="bg-surface-pure rounded-xl p-4 recipe-card-shadow flex justify-between items-center">
<div class="flex-1 pr-4">
<div class="flex items-center gap-2 mb-1">
<span class="bg-primary/10 text-primary px-2 py-0.5 rounded font-badge-caps text-[10px]">HEALTHY</span>
<div class="flex items-center gap-1 text-text-dimmed">
<span class="material-symbols-outlined text-[14px]">schedule</span>
<span class="text-unit-label font-unit-label">15m</span>
</div>
</div>
<h3 class="text-item-name font-item-name text-on-surface mb-1 leading-tight">Quinoa Avocado Salad</h3>
<p class="text-on-surface-variant/80 text-unit-label font-unit-label line-clamp-1">Zesty lemon-tahini dressing with cherry tomatoes and cucumber.</p>
</div>
<button aria-label="Add to Plan" class="h-thumb-touch w-thumb-touch flex items-center justify-center bg-primary-container/10 text-primary rounded-full active:scale-95 transition-transform">
<span class="material-symbols-outlined" style="font-variation-settings: &quot;FILL&quot; 1;">calendar_add_on</span>
</button>
</div>
<!-- Recipe Card 3 -->
<div class="bg-surface-pure rounded-xl p-4 recipe-card-shadow flex justify-between items-center">
<div class="flex-1 pr-4">
<div class="flex items-center gap-2 mb-1">
<span class="bg-primary/10 text-primary px-2 py-0.5 rounded font-badge-caps text-[10px]">QUICK</span>
<div class="flex items-center gap-1 text-text-dimmed">
<span class="material-symbols-outlined text-[14px]">schedule</span>
<span class="text-unit-label font-unit-label">10m</span>
</div>
</div>
<h3 class="text-item-name font-item-name text-on-surface mb-1 leading-tight">Spicy Tuna Wraps</h3>
<p class="text-on-surface-variant/80 text-unit-label font-unit-label line-clamp-1">Quick sriracha-mayo tuna mix with crisp lettuce in whole wheat tortillas.</p>
</div>
<button aria-label="Add to Plan" class="h-thumb-touch w-thumb-touch flex items-center justify-center bg-primary-container/10 text-primary rounded-full active:scale-95 transition-transform">
<span class="material-symbols-outlined" style="font-variation-settings: &quot;FILL&quot; 1;">calendar_add_on</span>
</button>
</div>
<!-- Recipe Card 4 -->
<div class="bg-surface-pure rounded-xl p-4 recipe-card-shadow flex justify-between items-center">
<div class="flex-1 pr-4">
<div class="flex items-center gap-2 mb-1">
<span class="bg-primary/10 text-primary px-2 py-0.5 rounded font-badge-caps text-[10px]">VEGETARIAN</span>
<div class="flex items-center gap-1 text-text-dimmed">
<span class="material-symbols-outlined text-[14px]">schedule</span>
<span class="text-unit-label font-unit-label">40m</span>
</div>
</div>
<h3 class="text-item-name font-item-name text-on-surface mb-1 leading-tight">Mushroom Risotto</h3>
<p class="text-on-surface-variant/80 text-unit-label font-unit-label line-clamp-1">Slow-cooked arborio rice with earthy portobello mushrooms and thyme.</p>
</div>
<button aria-label="Add to Plan" class="h-thumb-touch w-thumb-touch flex items-center justify-center rounded-full active:scale-95 transition-transform bg-primary-container/10 text-primary">
<span class="material-symbols-outlined" style="font-variation-settings: &quot;FILL&quot; 1;">calendar_add_on</span>
</button>
</div>
<!-- Recipe Card 5 -->
<div class="bg-surface-pure rounded-xl p-4 recipe-card-shadow flex justify-between items-center">
<div class="flex-1 pr-4">
<div class="flex items-center gap-2 mb-1">
<span class="bg-primary/10 text-primary px-2 py-0.5 rounded font-badge-caps text-[10px]">HEALTHY</span>
<div class="flex items-center gap-1 text-text-dimmed">
<span class="material-symbols-outlined text-[14px]">schedule</span>
<span class="text-unit-label font-unit-label">30m</span>
</div>
</div>
<h3 class="text-item-name font-item-name text-on-surface mb-1 leading-tight">Lemon Garlic Salmon</h3>
<p class="text-on-surface-variant/80 text-unit-label font-unit-label line-clamp-1">Baked salmon fillet seasoned with fresh lemon zest and roasted garlic.</p>
</div>
<button aria-label="Add to Plan" class="h-thumb-touch w-thumb-touch flex items-center justify-center bg-primary-container/10 text-primary rounded-full active:scale-95 transition-transform">
<span class="material-symbols-outlined" style="font-variation-settings: &quot;FILL&quot; 1;">calendar_add_on</span>
</button>
</div>
</section>
</main>
<!-- Floating Action Button -->
<button class="fixed bottom-24 right-6 w-14 h-14 bg-primary text-on-primary rounded-full shadow-2xl flex items-center justify-center active:scale-95 transition-all z-40"><span class="material-symbols-outlined">add</span></button>
<!-- BottomNavBar -->
<nav class="fixed bottom-0 w-full z-50 backdrop-blur-md bg-surface-pure/90 rounded-t-xl md:hidden border-t border-outline-variant shadow-lg h-[72px]"><div class="flex justify-around items-center h-full px-4 pb-safe"><a class="flex flex-col items-center justify-center text-on-surface-variant active:bg-surface-container-highest rounded-xl px-4 py-1 transition-colors" href="#"><span class="material-symbols-outlined">shopping_cart</span><span class="font-badge-caps text-badge-caps mt-1">List</span></a><a class="flex flex-col items-center justify-center text-on-surface-variant active:bg-surface-container-highest rounded-xl px-4 py-1 transition-colors" href="#"><span class="material-symbols-outlined">calendar_today</span><span class="font-badge-caps text-badge-caps mt-1">Plan</span></a><a class="flex flex-col items-center justify-center bg-primary-container text-on-primary-container rounded-full px-4 py-1 transition-all" href="#"><span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">restaurant_menu</span><span class="font-badge-caps text-badge-caps mt-1">Recipes</span></a><a class="flex flex-col items-center justify-center text-on-surface-variant active:bg-surface-container-highest rounded-xl px-4 py-1 transition-colors" href="#"><span class="material-symbols-outlined">inventory_2</span><span class="font-badge-caps text-badge-caps mt-1">Items</span></a></div></nav>
<script>
        // Micro-interaction for adding to plan
        document.querySelectorAll('[aria-label="Add to Plan"]').forEach(button => {
            button.addEventListener('click', function() {
                const icon = this.querySelector('.material-symbols-outlined');
                icon.textContent = 'check_circle';
                this.classList.remove('bg-primary-container/10', 'text-primary');
                this.classList.add('bg-primary', 'text-on-primary');
                
                setTimeout(() => {
                    icon.textContent = 'calendar_add_on';
                    this.classList.add('bg-primary-container/10', 'text-primary');
                    this.classList.remove('bg-primary', 'text-on-primary');
                }, 2000);
            });
        });

        // Chip selection interaction
        document.querySelectorAll('.flex.overflow-x-auto button').forEach(chip => {
            chip.addEventListener('click', function() {
                document.querySelectorAll('.flex.overflow-x-auto button').forEach(c => {
                    c.classList.remove('active-chip');
                    c.classList.add('bg-surface-pure', 'text-on-surface-variant');
                });
                this.classList.add('active-chip');
                this.classList.remove('bg-surface-pure', 'text-on-surface-variant');
            });
        });
    </script>




</body></html>