<script>
    // Micro-interaction for the buttons
    document.querySelectorAll('button').forEach(button => {
      button.addEventListener('mousedown', () => {
        button.classList.add('scale-95');
      });
      button.addEventListener('mouseup', () => {
        button.classList.remove('scale-95');
      });
      button.addEventListener('mouseleave', () => {
        button.classList.remove('scale-95');
      });
    });

    // Simple fade-in animation for drawer content
    window.addEventListener('DOMContentLoaded', () => {
      const drawerContent = document.querySelector('.overflow-y-auto');
      drawerContent.style.opacity = '0';
      drawerContent.style.transform = 'translateY(10px)';
      drawerContent.style.transition = 'all 0.6s ease-out';
      
      setTimeout(() => {
        drawerContent.style.opacity = '1';
        drawerContent.style.transform = 'translateY(0)';
      }, 100);
    });
  </script>










