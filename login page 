<script>
        const drawer = document.getElementById('settings-drawer');
        const backdrop = document.getElementById('drawer-backdrop');
        const closeBtn = document.getElementById('close-drawer');

        function toggleDrawer() {
            const isClosed = drawer.style.transform === 'translateX(100%)';
            drawer.style.transform = isClosed ? 'translateX(0)' : 'translateX(100%)';
            backdrop.style.opacity = isClosed ? '1' : '0';
            backdrop.style.pointerEvents = isClosed ? 'auto' : 'none';
        }

        closeBtn.addEventListener('click', toggleDrawer);
        backdrop.addEventListener('click', toggleDrawer);

        // Micro-interactions for stepper
        document.querySelectorAll('.thumb-zone-hit button').forEach(btn => {
            btn.addEventListener('touchstart', function() {
                this.classList.add('scale-90');
            });
            btn.addEventListener('touchend', function() {
                this.classList.remove('scale-90');
            });
        });

        // Horizontal swipe gesture to close
        let touchstartX = 0;
        let touchendX = 0;

        drawer.addEventListener('touchstart', e => {
            touchstartX = e.changedTouches[0].screenX;
        }, false);

        drawer.addEventListener('touchend', e => {
            touchendX = e.changedTouches[0].screenX;
            if (touchendX > touchstartX + 100) toggleDrawer();
        }, false);
    </script>
