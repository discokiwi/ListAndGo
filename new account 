<!DOCTYPE html>

<html class="light" lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0, viewport-fit=cover" name="viewport"/>
<title>Create Account | List&amp;GO</title>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@400;600;700;800&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
            display: inline-block;
            line-height: 1;
            text-transform: none;
            letter-spacing: normal;
            word-wrap: normal;
            white-space: nowrap;
            direction: ltr;
        }
        
        input:focus {
            outline: none;
            border-color: #2d6a4f !important;
            box-shadow: 0 0 0 2px rgba(45, 106, 79, 0.1);
        }

        .thumb-zone-safe {
            padding-bottom: env(safe-area-inset-bottom);
        }

        /* Subtle organic entrance */
        @keyframes slideUpFade {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .animate-entrance {
            animation: slideUpFade 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }
    </style>
<script id="tailwind-config">
        tailwind.config = {
          darkMode: "class",
          theme: {
            extend: {
              "colors": {
                      "on-tertiary": "#ffffff",
                      "error": "#ba1a1a",
                      "surface-container-highest": "#e2e2e5",
                      "surface-variant": "#e2e2e5",
                      "on-surface-variant": "#404943",
                      "tertiary-fixed": "#ffdad9",
                      "error-container": "#ffdad6",
                      "outline-variant": "#bfc9c1",
                      "on-secondary-fixed": "#111f0f",
                      "surface-muted": "#EEF1EF",
                      "inverse-primary": "#95d4b3",
                      "primary-fixed": "#b1f0ce",
                      "secondary": "#53634e",
                      "primary-container": "#2d6a4f",
                      "text-dimmed": "#636E72",
                      "surface-soft": "#F8F9F8",
                      "on-error-container": "#93000a",
                      "on-surface": "#1a1c1e",
                      "on-tertiary-fixed-variant": "#6f3537",
                      "on-primary-fixed-variant": "#0e5138",
                      "surface-container-low": "#f3f3f6",
                      "surface-bright": "#f9f9fc",
                      "on-secondary": "#ffffff",
                      "tertiary-fixed-dim": "#ffb3b3",
                      "secondary-container": "#d3e5cb",
                      "tertiary": "#713638",
                      "outline": "#707973",
                      "primary-fixed-dim": "#95d4b3",
                      "on-primary-container": "#a8e7c5",
                      "on-tertiary-container": "#ffcfce",
                      "background": "#f9f9fc",
                      "surface-container": "#eeeef0",
                      "inverse-surface": "#2f3133",
                      "on-error": "#ffffff",
                      "success-light": "#D8E2DC",
                      "on-tertiary-fixed": "#390b0e",
                      "surface-container-high": "#e8e8ea",
                      "tertiary-container": "#8d4d4e",
                      "on-background": "#1a1c1e",
                      "inverse-on-surface": "#f0f0f3",
                      "on-secondary-container": "#576752",
                      "surface-tint": "#2c694e",
                      "surface-dim": "#dadadc",
                      "on-secondary-fixed-variant": "#3b4b38",
                      "surface": "#f9f9fc",
                      "on-primary-fixed": "#002114",
                      "primary": "#0f5238",
                      "secondary-fixed": "#d6e8ce",
                      "surface-container-lowest": "#ffffff",
                      "surface-pure": "#FFFFFF",
                      "secondary-fixed-dim": "#baccb3",
                      "on-primary": "#ffffff"
              },
              "borderRadius": {
                      "DEFAULT": "0.25rem",
                      "lg": "0.5rem",
                      "xl": "0.75rem",
                      "full": "9999px"
              },
              "spacing": {
                      "base": "8px",
                      "safe-margin": "20px",
                      "list-item-gap": "12px",
                      "gutter": "16px",
                      "thumb-touch": "48px"
              },
              "fontFamily": {
                      "body-reg": ["Hanken Grotesk"],
                      "badge-caps": ["Hanken Grotesk"],
                      "item-name": ["Hanken Grotesk"],
                      "display-lg": ["Hanken Grotesk"],
                      "headline-md": ["Hanken Grotesk"],
                      "unit-label": ["Hanken Grotesk"]
              },
              "fontSize": {
                      "body-reg": ["16px", {"lineHeight": "1.5", "fontWeight": "400"}],
                      "badge-caps": ["12px", {"lineHeight": "1", "letterSpacing": "0.05em", "fontWeight": "700"}],
                      "item-name": ["18px", {"lineHeight": "1.4", "fontWeight": "600"}],
                      "display-lg": ["32px", {"lineHeight": "1.2", "letterSpacing": "-0.02em", "fontWeight": "700"}],
                      "headline-md": ["24px", {"lineHeight": "1.3", "fontWeight": "600"}],
                      "unit-label": ["14px", {"lineHeight": "1.2", "letterSpacing": "0.01em", "fontWeight": "400"}]
              }
            },
          },
        }
      </script>
<style>
    body {
      min-height: max(884px, 100dvh);
    }
  </style>
  </head>
<body class="bg-surface-soft font-body-reg text-on-surface selection:bg-primary-fixed min-h-screen flex flex-col">
<!-- TopAppBar -->
<header class="bg-surface-soft dark:bg-surface-dim flex items-center px-safe-margin py-4 w-full top-0 sticky z-50">
<button aria-label="Go back" class="active:scale-95 transition-transform hover:opacity-80 p-2 -ml-2">
<span class="material-symbols-outlined text-primary dark:text-primary-fixed-dim" style="font-size: 28px;">arrow_back</span>
</button>
<h1 class="font-headline-md text-headline-md text-primary dark:text-primary-fixed-dim ml-2">Create Account</h1>
</header>
<main class="flex-1 px-safe-margin flex flex-col justify-center max-w-md mx-auto w-full animate-entrance">
<!-- Value Proposition Section -->
<div class="mb-10 text-center">
<div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-secondary-container text-on-secondary-container mb-4 shadow-[0_4px_20px_rgba(0,0,0,0.05)]">
<span class="material-symbols-outlined" style="font-size: 32px;">kitchen</span>
</div>
<h2 class="font-headline-md text-headline-md text-on-surface mb-2">Welcome to the family</h2>
<p class="font-unit-label text-unit-label text-on-surface-variant max-w-[280px] mx-auto">
                Join List&amp;GO to sync your kitchen across devices and share lists with family.
            </p>
</div>
<!-- Signup Form -->
<form class="space-y-6">
<!-- Full Name -->
<div class="space-y-2">
<label class="font-unit-label text-unit-label text-on-surface-variant ml-1" for="full_name">Full Name</label>
<div class="relative">
<input class="w-full bg-surface-pure border-0 h-thumb-touch px-4 rounded-xl shadow-[0_4px_20px_rgba(0,0,0,0.05)] font-body-reg placeholder:text-outline-variant focus:ring-0 transition-all" id="full_name" name="full_name" placeholder="e.g. Jane Doe" required="" type="text"/>
<span class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 text-outline-variant" style="font-size: 20px;">person</span>
</div>
</div>
<!-- Email -->
<div class="space-y-2">
<label class="font-unit-label text-unit-label text-on-surface-variant ml-1" for="email">Email Address</label>
<div class="relative">
<input class="w-full bg-surface-pure border-0 h-thumb-touch px-4 rounded-xl shadow-[0_4px_20px_rgba(0,0,0,0.05)] font-body-reg placeholder:text-outline-variant focus:ring-0 transition-all" id="email" name="email" placeholder="jane@example.com" required="" type="email"/>
<span class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 text-outline-variant" style="font-size: 20px;">mail</span>
</div>
</div>
<!-- Password -->
<div class="space-y-2">
<label class="font-unit-label text-unit-label text-on-surface-variant ml-1" for="password">Password</label>
<div class="relative">
<input class="w-full bg-surface-pure border-0 h-thumb-touch px-4 rounded-xl shadow-[0_4px_20px_rgba(0,0,0,0.05)] font-body-reg placeholder:text-outline-variant focus:ring-0 transition-all" id="password" name="password" placeholder="••••••••" required="" type="password"/>
<button class="absolute right-4 top-1/2 -translate-y-1/2 text-outline-variant hover:text-on-surface-variant transition-colors" onclick="togglePassword()" type="button">
<span class="material-symbols-outlined" id="password-toggle" style="font-size: 20px;">visibility_off</span>
</button>
</div>
</div>
<!-- Primary Action -->
<div class="pt-4">
<button class="w-full h-thumb-touch bg-primary-container text-on-primary-container font-item-name text-item-name rounded-xl shadow-[0_4px_20px_rgba(0,0,0,0.1)] active:scale-[0.98] transition-all flex items-center justify-center gap-2" type="submit">
                    Create Account
                    <span class="material-symbols-outlined" style="font-size: 20px;">arrow_forward</span>
</button>
</div>
</form>
<!-- Secondary Action -->
<div class="mt-8 text-center pb-8">
<p class="font-unit-label text-unit-label text-on-surface-variant">
                Already have an account? 
                <a class="text-primary font-bold hover:underline underline-offset-4 ml-1" href="#">Log In</a>
</p>
</div>
</main>
<!-- Visual Accent Element (Subtle Background Detail) -->
<div class="fixed -bottom-10 -right-10 w-48 h-48 bg-secondary-container/20 rounded-full blur-3xl -z-10"></div>
<div class="fixed top-20 -left-10 w-32 h-32 bg-primary-fixed/10 rounded-full blur-3xl -z-10"></div>
<!-- Footer Space for Thumb Zone -->
<footer class="thumb-zone-safe mt-auto">
<div class="h-6"></div>
</footer>
<script>
        function togglePassword() {
            const passwordInput = document.getElementById('password');
            const toggleIcon = document.getElementById('password-toggle');
            if (passwordInput.type === 'password') {
                passwordInput.type = 'text';
                toggleIcon.innerText = 'visibility';
            } else {
                passwordInput.type = 'password';
                toggleIcon.innerText = 'visibility_off';
            }
        }

        // Add micro-interaction for form inputs
        document.querySelectorAll('input').forEach(input => {
            input.addEventListener('focus', () => {
                input.parentElement.parentElement.classList.add('scale-[1.01]');
                input.parentElement.parentElement.style.transition = 'transform 0.2s ease-out';
            });
            input.addEventListener('blur', () => {
                input.parentElement.parentElement.classList.remove('scale-[1.01]');
            });
        });
    </script>
</body></html>